server.port=8080
anthropic.api.key=YOUR_API_KEY_HERE
cors.allowed-origins=http://localhost:3000
logging.level.com.portfolio=DEBUG
youtube.api.key=YOUR_YOUTUBE_API_KEY_HERE
polygon.api.key=${POLYGON_API_KEY}
kakao.rest.key=${KAKAO_REST_KEY}
